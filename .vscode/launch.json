{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "backend (tsx watch)",
      "type": "node",
      "request": "launch",
      "runtimeExecutable": "pnpm",
      "runtimeArgs": ["-F", "@gtarp/backend", "dev"],
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal",
      "skipFiles": ["<node_internals>/**"]
    },
    {
      "name": "ai-orchestrator (tsx watch)",
      "type": "node",
      "request": "launch",
      "runtimeExecutable": "pnpm",
      "runtimeArgs": ["-F", "@gtarp/ai-orchestrator", "dev"],
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal",
      "skipFiles": ["<node_internals>/**"]
    },
    {
      "name": "event-worker (tsx watch)",
      "type": "node",
      "request": "launch",
      "runtimeExecutable": "pnpm",
      "runtimeArgs": ["-F", "@gtarp/event-worker", "dev"],
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal",
      "skipFiles": ["<node_internals>/**"]
    },
    {
      "name": "discord-bot (tsx watch)",
      "type": "node",
      "request": "launch",
      "runtimeExecutable": "pnpm",
      "runtimeArgs": ["-F", "@gtarp/discord-bot", "dev"],
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal",
      "skipFiles": ["<node_internals>/**"]
    },
    {
      "name": "web (next dev)",
      "type": "node-terminal",
      "request": "launch",
      "command": "pnpm -F @gtarp/web dev",
      "cwd": "${workspaceFolder}"
    },
    {
      "name": "vitest: current file",
      "type": "node",
      "request": "launch",
      "runtimeExecutable": "pnpm",
      "runtimeArgs": ["vitest", "run", "${relativeFile}"],
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal",
      "skipFiles": ["<node_internals>/**"]
    }
  ],
  "compounds": [
    {
      "name": "stack: backend + ai-orchestrator + event-worker",
      "configurations": [
        "backend (tsx watch)",
        "ai-orchestrator (tsx watch)",
        "event-worker (tsx watch)"
      ],
      "stopAll": true
    }
  ]
}
